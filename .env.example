# Public hostname configured after the VPS analysis
N8N_HOST=n8n.example.com
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com/
N8N_PROXY_HOPS=1

# Time zone
GENERIC_TIMEZONE=Europe/Berlin
TZ=Europe/Berlin

# Generate unique secrets locally. Never commit real values.
N8N_ENCRYPTION_KEY=replace-with-a-long-random-value
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-a-long-random-value

# Integrations
AIRTABLE_PERSONAL_ACCESS_TOKEN=replace-locally
AIRTABLE_BASE_ID=replace-locally
TELEGRAM_BOT_TOKEN=replace-locally
TELEGRAM_CHAT_ID=replace-locally
TRADINGVIEW_WEBHOOK_SECRET=replace-with-a-long-random-value
